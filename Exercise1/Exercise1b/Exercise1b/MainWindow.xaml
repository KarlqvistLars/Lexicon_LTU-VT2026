<Window x:Class="Exercise1b.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Exercise1b"
        mc:Ignorable="d"
        Title="Personalregister" MinHeight="300" MinWidth="600" MaxHeight="300" MaxWidth="600">
    <Grid>
        <Button x:Name="Clear_Button" Content="Clear" Width="80" Height="30" HorizontalAlignment="Left" Margin="25,0,0,25" VerticalAlignment="Bottom" Click="Clear_Button_Click"/>
        <Button x:Name="Exit_Button" Content="Exit" Width="80" Height="30" HorizontalAlignment="Left" Margin="125,0,0,25" VerticalAlignment="Bottom" Click="Exit_Button_Click"/>
        <Button x:Name="Add_Button" Content="Add" Width="80" Height="30" HorizontalAlignment="Left" Margin="25,0,0,65" VerticalAlignment="Bottom" Click="Add_Button_Click"/>
        <Button x:Name="Remove_Button" Content="Remove" Width="80" Height="30" HorizontalAlignment="Left" Margin="125,0,0,65" VerticalAlignment="Bottom" Click="Remove_Button_Click"/>
        <Label x:Name="LabelNamn" FontSize="10" Content="Namn" HorizontalAlignment="Left" Margin="25,25,0,0" VerticalAlignment="Top"/>
        <TextBox x:Name="TextBoxNamn" HorizontalAlignment="Left" Margin="25,45,0,0" TextWrapping="Wrap" Text="" VerticalAlignment="Top" Width="200" Height="20"/>
        <Label x:Name="LabelFData" FontSize="10" Content="Födelseår" HorizontalAlignment="Left" Margin="25,65,0,0" VerticalAlignment="Top"/>
        <TextBox x:Name="TextBoxFData" HorizontalAlignment="Left" Margin="25,85,0,0" TextWrapping="Wrap" Text="" VerticalAlignment="Top" Width="200" Height="20"/>
        <Label x:Name="LabelHourlyRate" FontSize="10" Content="Timlön" HorizontalAlignment="Left" Margin="25,105,0,0" VerticalAlignment="Top"/>
        <TextBox x:Name="TextBoxHourlyRate" HorizontalAlignment="Left" Margin="25,125,0,0" TextWrapping="Wrap" Text="" VerticalAlignment="Top" Width="200" Height="20"/>
        <ListView x:Name="EmployeeListView" 
                  ItemsSource="{Binding Employees}" 
                  HorizontalAlignment="Stretch" 
                    AlternationCount="2"
                  Margin="260,25,25,25" VerticalAlignment="Stretch" SelectionChanged="EmployeeListView_SelectionChanged">

            <ListView.Resources>
                <Style TargetType="ListViewItem">
                    <Style.Triggers>
                        <Trigger Property="ItemsControl.AlternationIndex" Value="1">
                            <Setter Property="Background" Value="LightGreen"/>
                        </Trigger>
                    </Style.Triggers>
                </Style>
            </ListView.Resources>

            <ListView.View>
                <GridView>
                    <GridViewColumn Header="Namn" Width="160" DisplayMemberBinding="{Binding Name}" />
                    <GridViewColumn Header="Född" Width="50" DisplayMemberBinding="{Binding Born}" />
                    <GridViewColumn Header="Timlön" Width="70" DisplayMemberBinding="{Binding HourlyRate}" />
                </GridView>
            </ListView.View>

        </ListView>
    </Grid>
</Window>
