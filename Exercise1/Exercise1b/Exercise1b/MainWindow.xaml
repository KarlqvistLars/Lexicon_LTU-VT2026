<Window x:Class="Exercise1b.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Exercise1b"
        mc:Ignorable="d"
        Title="Personalregister" Height="280" Width="600">
    <Grid>
        <Button x:Name="OK_Button" Content="OK" Width="80" Height="30" HorizontalAlignment="Left" Margin="25,0,0,25" VerticalAlignment="Bottom"/>
        <Button x:Name="Cancel_Button" Content="Cancel" Width="80" Height="30" HorizontalAlignment="Left" Margin="125,0,0,25" VerticalAlignment="Bottom"/>
        <Label x:Name="LabelNamn" Content="Namn" HorizontalAlignment="Left" Margin="25,25,0,0" VerticalAlignment="Top"/>
        <TextBox x:Name="TextBoxNamn" HorizontalAlignment="Left" Margin="25,45,0,0" TextWrapping="Wrap" Text="TextBox" VerticalAlignment="Top" Width="200" Height="20"/>
        <Label x:Name="LabelFData" Content="Födelseår" HorizontalAlignment="Left" Margin="25,65,0,0" VerticalAlignment="Top"/>
        <TextBox x:Name="TextBoxFData" HorizontalAlignment="Left" Margin="25,85,0,0" TextWrapping="Wrap" Text="TextBox" VerticalAlignment="Top" Width="200" Height="20"/>
        <Label x:Name="LabelHourlyRate" Content="Timlön" HorizontalAlignment="Left" Margin="25,105,0,0" VerticalAlignment="Top"/>
        <TextBox x:Name="TextBoxHourlyRate" HorizontalAlignment="Left" Margin="25,125,0,0" TextWrapping="Wrap" Text="TextBox" VerticalAlignment="Top" Width="200" Height="20"/>
        <ListBox HorizontalAlignment="Stretch" Margin="260,25,25,25" VerticalAlignment="Stretch" d:ItemsSource="{d:SampleData ItemCount=5}"/>
    </Grid>
</Window>
