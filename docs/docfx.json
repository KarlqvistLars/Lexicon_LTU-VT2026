        }
      ],
      "dest": "api/Exercise1b.Core/",
      "properties": {
        "IncludePrivateMembers": "true",
        "IncludeInternalMembers": "true"
      }
    },
    {
      "src": [
        {
          "src": "..",
          "files": [ "Exercise2/Exercise2/Exercise2/Exercise2.csproj" ]
        }
      ],
      "dest": "api/Exercise2/",
      "properties": {
        "IncludePrivateMembers": "true",
        "IncludeInternalMembers": "true"
      }
    }
  ],
  "build": {
