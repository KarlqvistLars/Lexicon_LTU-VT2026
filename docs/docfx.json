{
  "metadata": [
    {
      "src": [
        {
          "src": "..",
          "files": [ "Exercise1/Exercise1/Exercise1/Exercise1.csproj" ]
        }
      ],
      "dest": "api/Exercise1",
          "properties": {
            "IncludePrivateMembers": "true",
            "IncludeInternalMembers": "true"
      }
    },
    {
      "src": [
        {
          "src": "..",
          "files": [ "Exercise2/Exercise2/Exercise2/Exercise2.csproj" ]
        }
      ],
      "dest": "api/Exercise2",
        "properties": {
            "IncludePrivateMembers": "true",
            "IncludeInternalMembers": "true"
        }
      }
